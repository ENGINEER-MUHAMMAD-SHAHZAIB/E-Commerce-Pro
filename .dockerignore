# Ignore node_modules (will be installed inside container)
node_modules

# Ignore local build output (not needed)
build
dist

# Ignore environment files if you don’t want them in image
.env
.env.local
.env.development
.env.test

# Ignore git files
.git
.gitignore

# Ignore logs
*.log
npm-debug.log*

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE/editor configs
.vscode
.idea
